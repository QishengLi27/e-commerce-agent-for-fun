# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL with pgvector extension (SQLAlchemy format)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ecommerce

# ─── LLM / Embeddings (GLM-4 via OpenAI-compatible API) ──────────────────────
OPENAI_API_KEY=your-glm-4-api-key-here
OPENAI_API_BASE=https://open.bigmodel.cn/api/paas/v4/
OPENAI_MODEL=glm-4-flash
EMBEDDING_MODEL=embedding-2

# ─── Redis (optional — for session memory in production) ─────────────────────
# REDIS_URL=redis://localhost:6379/0

# ─── API / CORS ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
API_HOST=0.0.0.0
API_PORT=8000

# ─── Retrieval ───────────────────────────────────────────────────────────────
# Policy retrieval mode for the knowledge-augmented agent.
# Options: vector | graph | hybrid
#   vector — existing hybrid RAG (pgvector + BM25 + RRF + LLM re-rank)
#   graph  — PostgreSQL knowledge graph (product → category → policy traversal)
#   hybrid — graph first, falls back to vector if no structured match
RETRIEVAL_MODE=hybrid

# ─── Intent Classification ──────────────────────────────────────────────────
# How the agent determines what the user is asking about.
# Options: keyword | llm_hybrid | semantic
#   keyword    — <100 products: entity+keyword matching with LLM fallback
#                (substring match on known product names, zero LLM cost for most
#                queries, deterministic and explainable)
#   llm_hybrid — 100-10K products: LLM extracts entities + intent, KG validates
#                (LLM interprets rephrasing, KG confirms products actually exist)
#   semantic   — 10K+ products: vector search top-K candidates + LLM + KG
#                (LLM never sees full catalog, only top-5 semantically similar
#                products, scales to millions of items)
CLASSIFICATION_MODE=keyword

# ─── Checkpointer ────────────────────────────────────────────────────────────
# Session persistence backend for resumable conversations.
# Options: postgres | memory
#   postgres — persists across restarts (production)
#   memory   — lost on restart (development)
CHECKPOINT_TYPE=postgres

# ─── App Paths ───────────────────────────────────────────────────────────────
DATA_DIR=data
MEMORY_FILEPATH=data/memory_store.json

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
